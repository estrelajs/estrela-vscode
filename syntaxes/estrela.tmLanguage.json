      "end": "(?=\\s*+[^=\\s])",
      "name": "meta.directive.$1.estrela",
      "patterns": [
        {
          "begin": "=",
          "beginCaptures": {
            "0": {
              "name": "punctuation.separator.key-value.estrela"
