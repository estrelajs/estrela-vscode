    "attributes-value": {
      "patterns": [
        {
          "include": "#interpolation"
        },
        {
          "match": "(?:(['\"])([0-9._]+[\\w%]{,4})(\\1))|(?:([0-9._]+[\\w%]{,4})(?=\\s|/?>))",
