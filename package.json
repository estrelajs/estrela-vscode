{
  "name": "estrela-vscode",
  "displayName": "Estrela",
  "description": "Syntax Highlight for Estrela",
  "icon": "assets/logo.png",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.65.0"
  },
  "license": "MIT",
  "main": "./dist/main.js",
  "publisher": "estrelajs",
  "scripts": {
    "build": "npm run build:client && npm run build:server",
    "build:client": "esbuild ./client/src/extension.ts --bundle --outfile=dist/main.js --external:vscode --format=cjs --platform=node --minify",
    "build:server": "esbuild ./server/src/server.ts --bundle --outfile=dist/server.js --external:vscode --format=cjs --platform=node --minify",
    "test-compile": "tsc -p ./",
    "compile": "tsc -b",
    "watch": "tsc -b -w",
    "lint": "eslint ./client/src ./server/src --ext .ts,.tsx",
    "postinstall": "cd client && npm install && cd ../server && npm install && cd .."
  },
  "bugs": {
    "url": "https://github.com/estrelajs/estrela-vscode/issues"
  },
  "homepage": "https://github.com/estrelajs/estrela-vscode#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/estrelajs/estrela-vscode.git"
  },
  "galleryBanner": {
    "color": "#009dff",
    "theme": "light"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "estrela",
    "vscode"
  ],
  "activationEvents": [
    "onLanguage:estrela"
  ],
  "contributes": {
    "languages": [
      {
        "id": "estrela",
        "aliases": [
          "Estrela",
          "estrela"
        ],
        "extensions": [
          ".estrela"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "estrela",
        "scopeName": "source.estrela",
        "path": "./syntaxes/estrela.tmLanguage.json",
        "embeddedLanguages": {
          "source.js": "javascript",
          "source.ts": "typescript",
          "source.jsx": "javascriptreact",
          "source.tsx": "typescriptreact"
        }
      }
    ]
  },
  "devDependencies": {
    "@types/mocha": "^9.1.0",
    "@types/node": "^17.0.21",
    "@typescript-eslint/eslint-plugin": "^5.14.0",
    "@typescript-eslint/parser": "^5.14.0",
    "esbuild": "^0.14.25",
    "eslint": "^8.10.0",
    "typescript": "^4.6.2"
  }
}
