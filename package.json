{
  "name": "estrela-vscode",
  "displayName": "Estrela for Vscode",
  "description": "Highlight syntax for Estrela files for vscode",
  "icon": "assets/logo.png",
  "version": "1.0.3",
  "engines": {
    "vscode": "^1.65.0"
  },
  "license": "MIT",
  "main": "./dist/client/extension.js",
  "publisher": "estrelajs",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -b",
    "watch": "tsc -b -w",
    "lint": "eslint ./client/src ./server/src --ext .ts,.tsx"
  },
  "bugs": {
    "url": "https://github.com/estrelajs/estrela-vscode/issues"
  },
  "homepage": "https://github.com/estrelajs/estrela-vscode#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/estrelajs/estrela-vscode.git"
  },
  "galleryBanner": {
    "color": "#009dff",
    "theme": "light"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "estrela",
    "vscode"
  ],
  "activationEvents": [
    "onLanguage:estrela"
  ],
  "contributes": {
    "languages": [
      {
        "id": "estrela",
        "aliases": [
          "Estrela",
          "estrela"
        ],
        "extensions": [
          ".estrela"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "estrela",
        "scopeName": "source.estrela",
        "path": "./syntaxes/estrela.tmLanguage.json",
        "embeddedLanguages": {
          "text.html.basic": "html",
          "text.html.markdown": "markdown",
          "text.pug": "jade",
          "source.css": "css",
          "source.css.less": "less",
          "source.css.scss": "scss",
          "source.css.postcss": "postcss",
          "source.sass": "sass",
          "source.stylus": "stylus",
          "source.js": "javascript",
          "source.ts": "typescript",
          "source.jsx": "javascriptreact",
          "source.tsx": "typescriptreact",
          "source.coffee": "coffeescript"
        }
      }
    ]
  },
  "dependencies": {
    "chokidar": "^3.5.3",
    "lodash": "^4.17.21",
    "magic-string": "^0.26.1",
    "prettier": "^2.5.1",
    "source-map": "^0.7.3",
    "typescript": "^4.6.2",
    "vscode-css-languageservice": "^5.1.13",
    "vscode-emmet-helper": "^2.6.4",
    "vscode-html-languageservice": "^3.0.3",
    "vscode-languageclient": "^6.1.3",
    "vscode-languageserver-textdocument": "^1.0.1",
    "vscode-languageserver": "^7.0.0",
    "vscode-uri": "^3.0.3"
  },
  "devDependencies": {
    "@types/lodash": "^4.14.179",
    "@types/mocha": "^9.1.0",
    "@types/node": "^17.0.21",
    "@types/prettier": "^2.4.4",
    "@types/vscode": "^1.43.0",
    "@typescript-eslint/eslint-plugin": "^5.14.0",
    "@typescript-eslint/parser": "^5.14.0",
    "eslint": "^8.10.0"
  }
}
